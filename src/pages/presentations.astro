---
import BaseLayout from "../layouts/BaseLayout.astro";

const presentations = [
  {
    title: "Be the Legacy: Solid Organ Donation Awareness",
    desc: "Overview of the Veloxis Organ Donation Challenge Project Grant and the Be the Legacy initiative — educational event planning, goals, and award outcomes.",
    type: "PowerPoint",
    topic: "Organ Donation & Transplant",
    id: "1JwB09ul2-LucxQnWOF6Hn2EtwMaJTK7N",
  },
  {
    title: "Chatman Case Presentation: Classic Hodgkin Lymphoma",
    desc: "Inpatient oncology case featuring a Stage IV CHL patient — ABVD regimen, toxicity monitoring, salvage therapy, and autologous SCT outcomes.",
    type: "PowerPoint",
    topic: "Oncology",
    id: "1OyqkHqrY0VVF7dHRtW-aeW3E8zjddSLy",
  },
  {
    title: "Glioblastoma Multiforme",
    desc: "Epidemiology, pathophysiology, the Stupp regimen landmark trial, and current treatment management for GBM (WHO Grade IV astrocytoma).",
    type: "PowerPoint",
    topic: "Neuroscience",
    id: "1S_tdv10J8zCSs6lKakV8aExiY_i78qNl",
  },
  {
    title: "Transplant Debate: Xenotransplantation",
    desc: "PHAR 666 structured debate examining the pro/con arguments for xenotransplantation — organ shortage burden, antibody-mediated rejection, and ethical concerns.",
    type: "PowerPoint",
    topic: "Solid Organ Transplant",
    id: "1tctrMdsYxPN0YbwWKcAw0ToItgxz_ckC",
  },
  {
    title: "AI in Pharmacy Education — Policy Proposal",
    desc: "VCU School of Pharmacy GLDP 2026 project proposing a standardized AI use policy across all PharmD coursework, with budget analysis and implementation roadmap.",
    type: "PowerPoint",
    topic: "Healthcare Policy",
    id: "1B4GAbU3A3jhqDMxoSe-V8Nf5SpFbnb3m",
  },
  {
    title: "Alternative Medicine: Fenugreek & Asian Ginseng",
    desc: "Team presentation covering mechanism of action, common uses, drug interactions, and patient counseling for two widely used herbal supplements.",
    type: "PowerPoint",
    topic: "Pharmacognosy",
    id: "1dlutn6GEYP_1Rau_Ke-FVNnVwv0SUOMS",
  },
  {
    title: "Gepirone (Exxua) — Drug Presentation & Patient Trifold",
    desc: "FDA-approved serotonin modulator for MDD — mechanism, dosing, interactions, adverse effects, and a patient-facing educational trifold.",
    type: "PDF",
    topic: "Psychiatric Pharmacy",
    id: "1XCsI1nKz-gFs64t44p78ayFD62846pNc",
  },
];

const topicColors: Record<string, string> = {
  "Organ Donation & Transplant": "teal",
  "Oncology": "purple",
  "Neuroscience": "purple",
  "Solid Organ Transplant": "teal",
  "Healthcare Policy": "gold",
  "Pharmacognosy": "teal",
  "Psychiatric Pharmacy": "purple",
};
---

<BaseLayout title="Presentations" description="Academic presentations by Nina Chatman — PharmD Candidate at VCU">
  <div class="container">
    <header class="page-header">
      <h1>Presentations</h1>
      <p>Academic and clinical presentations from rotations, coursework, and leadership projects.</p>
    </header>

    <div class="pres-grid">
      {presentations.map(({ title, desc, type, topic, id }) => (
        <a
          href={`https://drive.google.com/file/d/${id}/view`}
          target="_blank"
          rel="noopener noreferrer"
          class="pres-card"
        >
          <div class="card-top">
            <span class={`topic-tag topic-tag--${topicColors[topic] ?? "teal"}`}>{topic}</span>
            <span class="type-badge">{type === "PDF" ? "📄 PDF" : "📊 Slides"}</span>
          </div>
          <h2>{title}</h2>
          <p class="card-desc">{desc}</p>
          <span class="view-link">Open in Drive →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .container { padding-top: 3rem; padding-bottom: 4rem; }

  .page-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
  }
  .page-header h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: var(--muted); }

  .pres-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .pres-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    transition: all 0.2s;
    cursor: pointer;
  }
  .pres-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(13, 148, 136, 0.1);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .topic-tag {
    display: inline-block;
    border-radius: 99px;
    padding: 0.2rem 0.75rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .topic-tag--teal {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--accent);
  }
  .topic-tag--purple {
    background: var(--accent2-dim);
    color: var(--accent2);
    border: 1px solid var(--accent2);
  }
  .topic-tag--gold {
    background: #fefce8;
    color: #a16207;
    border: 1px solid #fde047;
  }

  .type-badge {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
  }

  .pres-card h2 {
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
  }

  .card-desc {
    color: var(--muted);
    font-size: 0.855rem;
    line-height: 1.65;
    flex: 1;
  }

  .view-link {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .pres-grid { grid-template-columns: 1fr; }
  }
</style>
